PORT=5000
# Exemplo de DATABASE_URL usando Neon (PostgreSQL Serverless gratuito)
# Para usar:
# 1. Acesse https://neon.tech
# 2. Crie uma conta (requer email apenas)
# 3. Crie um projeto PostgreSQL
# 4. Copie a connection string e substitua no DATABASE_URL abaixo
# 5. Adicione "?sslmode=require" se não estiver presente
DATABASE_URL="postgresql://user:password@your-remote-db-host:5432/vmb_crm?schema=public"
JWT_SECRET="super-secret-jwt-key-prototype-crm-2026"
UPLOAD_DIR="./uploads"
