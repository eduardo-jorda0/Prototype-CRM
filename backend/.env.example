PORT=5000
# Configure a remote PostgreSQL database URL - DO NOT use localhost
# Examples:
# - Render: postgresql://user:password@your-app.render.db:5432/prototype_crm?schema=public
# - Railway: postgresql://user:password@your-railway-host:5432/prototype_crm?schema=public
# - AWS RDS: postgresql://admin:password@your-rds-instance.amazonaws.com:5432/prototype_crm?schema=public
# - Neon: postgresql://user:password@pg.neon.tech/prototype_crm?schema=public&sslmode=require
DATABASE_URL="postgresql://user:password@your-remote-db-host:5432/prototype_crm?schema=public"
JWT_SECRET="super-secret-jwt-key-prototype-crm-2026"
UPLOAD_DIR="./uploads"
